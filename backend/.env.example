# Deployment
# Set to production in every production web and worker service so fail-closed
# startup validation does not depend only on public URL/Sentry inference.
DEPLOYMENT_ENV=development

# Database
DATABASE_URL=postgresql://tali:tali_dev_password@localhost:5432/tali_db
# 0 derives DATABASE_POOL_SIZE + DATABASE_MAX_OVERFLOW. This separate lazy
# QueuePool prevents long advisory-lock/provider calls from starving app SQL.
DATABASE_WORKSPACE_LOCK_POOL_SIZE=0

# Security
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Railway production only: trust the edge's canonical X-Real-IP value so
# per-client abuse limits do not collapse onto one shared proxy address.
TRUST_RAILWAY_X_REAL_IP=false
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# E2B
E2B_API_KEY=your-e2b-api-key

# Claude / Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# Valid pinned Haiku 4.5 defaults; leave the deprecated scoring selector empty
# unless a compatibility deployment requires it to exactly match CLAUDE_MODEL.
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_SCORING_MODEL=
CLAUDE_SCORING_BATCH_MODEL=claude-haiku-4-5-20251001
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
# Empty inherits the pinned CLAUDE_MODEL. Set only to an explicit snapshot id.
CLAUDE_AGENT_AUTONOMOUS_MODEL=

# Usage metering may remain false for local shadow validation, but every
# production web/worker process fails startup unless it is true.
USAGE_METER_LIVE=false
# Emergency-only production bypass. If enabled, credit gates remain disabled
# and /health reports shadow_emergency_override as degraded/unready.
USAGE_METER_ALLOW_PRODUCTION_SHADOW_EMERGENCY=false

# GitHub assessment repositories
# Set GITHUB_MOCK_MODE=false in production to create real repos/branches and push candidate code.
GITHUB_ORG=taali-assessments
GITHUB_TOKEN=your-github-token-with-repo-scope
GITHUB_MOCK_MODE=true

# Workable
WORKABLE_CLIENT_ID=your-workable-client-id
WORKABLE_CLIENT_SECRET=your-workable-client-secret
WORKABLE_WEBHOOK_SECRET=your-workable-webhook-secret

# Native Taali careers pages. Required in production when requisitions are not
# linked to an ATS job; production agent activation fails closed if it is off.
ATS_PUBLIC_APPLY_ENABLED=false

# One-switch role setup: automatically author and link an inactive assessment
# draft. A recruiter still approves its candidate-facing content before Turn on.
AUTO_GENERATE_ASSESSMENT_TASKS=true

# Stripe
STRIPE_API_KEY=your-stripe-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Lemon Squeezy
LEMON_API_KEY=your-lemon-api-key
LEMON_STORE_ID=your-lemon-store-id
LEMON_WEBHOOK_SECRET=your-lemon-webhook-secret
LEMON_TEST_MODE=true
# {"starter_5":{"variant_id":"12345","credits":5,"label":"Starter (5 credits)"}, ...}
LEMON_PACKS_JSON={"starter_5":{"variant_id":"0","credits":5,"label":"Starter (5 credits)"},"growth_10":{"variant_id":"0","credits":10,"label":"Growth (10 credits)"},"scale_20":{"variant_id":"0","credits":20,"label":"Scale (20 credits)"}}

# Resend
RESEND_API_KEY=your-resend-api-key

# Redis
REDIS_URL=redis://localhost:6379
# Supported production command: python -m app.scripts.railway_worker_start
# These defaults consume both required queues and run the single Beat scheduler.
TALI_WORKER_QUEUES=celery,scoring
TALI_WORKER_CONCURRENCY=4
TALI_WORKER_BEAT=true

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Comma-separated extra CORS origins (e.g. Vercel preview URL)
CORS_EXTRA_ORIGINS=
# Optional regex for additional CORS origins (e.g. https://.*\.vercel\.app)
CORS_ALLOW_ORIGIN_REGEX=

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=tali-assessments
AWS_REGION=us-east-1

# Sentry (optional — also triggers production mode: stricter CORS, no /api/docs, SECRET_KEY validation)
SENTRY_DSN=
