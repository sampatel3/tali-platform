{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "routes": [
    {
      "src": "/assets/(.*)-[A-Za-z0-9_-]{8}\\.[A-Za-z0-9]+",
      "caseSensitive": true,
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/deck/links",
      "caseSensitive": true,
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      }
    },
    {
      "src": "/deck/(.+)",
      "caseSensitive": true,
      "dest": "https://api.taali.ai/deck/$1",
      "headers": {
        "Cache-Control": "private, no-store, max-age=0",
        "X-Robots-Tag": "noindex, nofollow, noarchive",
        "Referrer-Policy": "no-referrer"
      }
    },
    {
      "src": "/assets(?:/(.*))?",
      "caseSensitive": true,
      "headers": {
        "Cache-Control": "private, no-store, max-age=0"
      },
      "status": 404
    },
    {
      "src": "/assess/(.*)",
      "caseSensitive": true,
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Referrer-Policy": "no-referrer",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), clipboard-read=(), clipboard-write=(), display-capture=(), usb=(), serial=(), hid=()",
        "Content-Security-Policy": "default-src 'self'; base-uri 'none'; object-src 'none'; form-action 'none'; frame-ancestors 'none'; frame-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://api.taali.ai https://*.up.railway.app; worker-src 'self' blob:; media-src 'none'; manifest-src 'self'; upgrade-insecure-requests",
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet",
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Resource-Policy": "same-origin",
        "X-Permitted-Cross-Domain-Policies": "none"
      }
    },
    {
      "src": "/assessment/(.*)",
      "caseSensitive": true,
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Referrer-Policy": "no-referrer",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), clipboard-read=(), clipboard-write=(), display-capture=(), usb=(), serial=(), hid=()",
        "Content-Security-Policy": "default-src 'self'; base-uri 'none'; object-src 'none'; form-action 'none'; frame-ancestors 'self'; frame-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://api.taali.ai https://*.up.railway.app; worker-src 'self' blob:; media-src 'none'; manifest-src 'self'; upgrade-insecure-requests",
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet",
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Resource-Policy": "same-origin",
        "X-Permitted-Cross-Domain-Policies": "none"
      }
    },
    {
      "src": "/agentic-hiring",
      "caseSensitive": true,
      "dest": "/agentic-hiring.html"
    },
    {
      "src": "/ai-native-hiring",
      "caseSensitive": true,
      "dest": "/ai-native-hiring.html"
    },
    {
      "src": "/ai-native-assessments",
      "caseSensitive": true,
      "dest": "/ai-native-assessments.html"
    },
    {
      "src": "/report-preview",
      "caseSensitive": true,
      "dest": "/report-preview.html"
    },
    {
      "src": "/home-preview",
      "caseSensitive": true,
      "dest": "/home-preview.html"
    },
    {
      "src": "/jobs-preview",
      "caseSensitive": true,
      "dest": "/jobs-preview.html"
    },
    {
      "src": "/pipeline-preview",
      "caseSensitive": true,
      "dest": "/pipeline-preview.html"
    },
    {
      "src": "/search-preview",
      "caseSensitive": true,
      "dest": "/search-preview.html"
    },
    {
      "src": "/analytics-preview",
      "caseSensitive": true,
      "dest": "/analytics-preview.html"
    },
    {
      "src": "/settings-preview",
      "caseSensitive": true,
      "dest": "/settings-preview.html"
    },
    {
      "src": "/(.*)",
      "caseSensitive": true,
      "dest": "/index.html"
    }
  ]
}
