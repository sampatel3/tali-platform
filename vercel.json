{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    { "source": "/agentic-hiring", "destination": "/agentic-hiring.html" },
    { "source": "/ai-native-hiring", "destination": "/ai-native-hiring.html" },
    { "source": "/ai-native-assessments", "destination": "/ai-native-assessments.html" },
    { "source": "/report-preview", "destination": "/report-preview.html" },
    { "source": "/home-preview", "destination": "/home-preview.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
