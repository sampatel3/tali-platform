# Backend API base URL (no trailing slash or newline)
VITE_API_URL=http://localhost:8000
# Optional full developer API base; defaults to VITE_API_URL + /public/v1.
# VITE_PUBLIC_API_BASE_URL=https://api.example.com/public/v1
# Stripe publishable key (optional until billing enabled)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
