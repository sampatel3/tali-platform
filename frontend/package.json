{
  "name": "taali-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "node scripts/run-vitest-clean.mjs",
    "test:watch": "vitest",
    "lint:js": "eslint . --max-warnings=0",
    "check:architecture": "node scripts/check-architecture.mjs && node scripts/check-motion-system.mjs && node scripts/check-chat-system.mjs && vitest run scripts/check-architecture.test.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "generate:landing-fixtures": "node scripts/generate-data-engineer-fixtures.mjs",
    "typecheck": "tsc --noEmit",
    "lint:ui": "node scripts/lint-ui.mjs",
    "lint:motion": "node scripts/check-motion-system.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.5",
    "cytoscape": "^3.30.4",
    "lenis": "^1.3.25",
    "lucide-react": "^0.563.0",
    "motion": "^12.42.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "picomatch@<=2.3.1": "2.3.2"
  }
}
