{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["vitest/globals", "vite/client"],
    "paths": {
      "@mainspring/ui": ["./vendor/mainspring/ui/ErrorBoundary.tsx"]
    }
  },
  "include": ["src/**/*.ts", "vendor/mainspring/**/*.ts", "vendor/mainspring/**/*.tsx"]
}
