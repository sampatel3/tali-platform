{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "redirects": [
    { "source": "/home-preview.html", "destination": "/home-preview", "permanent": false },
    {
      "source": "/jobs-preview.html",
      "has": [{ "type": "query", "key": "agent", "value": "(?<agent>paused|loading)" }],
      "destination": "/jobs-preview?agent=:agent",
      "permanent": false
    },
    { "source": "/jobs-preview.html", "destination": "/jobs-preview", "permanent": false },
    { "source": "/report-preview.html", "destination": "/report-preview", "permanent": false },
    { "source": "/analytics-preview.html", "destination": "/analytics-preview", "permanent": false }
  ],
  "rewrites": [
    { "source": "/agentic-hiring", "destination": "/agentic-hiring.html" },
    { "source": "/ai-native-hiring", "destination": "/ai-native-hiring.html" },
    { "source": "/ai-native-assessments", "destination": "/ai-native-assessments.html" },
    { "source": "/developers", "destination": "/developers.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/ai-native-coding-and-knowledge-work", "destination": "/blog-ai-native.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/pipeline-preview", "destination": "/pipeline-preview.html" },
    { "source": "/search-preview", "destination": "/search-preview.html" },
    { "source": "/settings-preview", "destination": "/settings-preview.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https: wss:; frame-src 'self'; worker-src 'self' blob:; form-action 'self' mailto:" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(self), payment=()" }
      ]
    }
  ]
}
